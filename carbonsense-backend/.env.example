# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5000

# Database (PostgreSQL - Optional)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=carbonsense
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_HOST=localhost
# DB_PORT=5432

# ── Recommendations: n8n + Supabase backend ────────────────────────────────
# Switch to 'template' to bypass n8n entirely (uses sector templates only)
RECOMMENDATIONS_BACKEND=n8n

# n8n webhook root, no trailing slash. e.g. https://yourname.app.n8n.cloud/webhook
N8N_WEBHOOK_BASE=
# Shared secret sent in X-Carbonsense-Token header; must match n8n env var
N8N_SHARED_SECRET=
N8N_TIMEOUT_SECONDS=60

# Supabase (for seed_data_chunks command + future read paths)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=

# OpenAI (only used by `python manage.py seed_data_chunks`)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Cache TTL for local-side fallback recommendations
RECOMMENDATION_CACHE_TTL_HOURS=24

# ── Legacy (to remove after cutover) ───────────────────────────────────────
GROQ_API_KEY=
