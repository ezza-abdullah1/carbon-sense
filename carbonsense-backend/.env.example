# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5000

# Database (PostgreSQL - Optional)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=carbonsense
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_HOST=localhost
# DB_PORT=5432

# AI / RAG Configuration
# LLM provider: gemini (recommended, free) | openrouter | groq
LLM_PROVIDER=openrouter
LLM_CRITIC_PROVIDER=openrouter

# # Gemini (free at aistudio.google.com/apikey, ~1500 req/day on gemini-2.0-flash)
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.0-flash

# OpenRouter (free models at openrouter.ai/keys; deepseek/deepseek-chat:free is recommended)
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free


# Groq (kept as fallback; currently disabled)
GROQ_API_KEY=your-groq-api-key-here

# Web search for current 2026 references
# Provider: tavily (recommended, free 1000/mo at app.tavily.com) | ddg
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=your-tavily-api-key-here

# Behaviour
RECOMMENDATION_CACHE_TTL_HOURS=24
RECOMMENDATION_CHAT_HISTORY_TURNS=6
RECOMMENDATION_CRITIC_ENABLED=True
